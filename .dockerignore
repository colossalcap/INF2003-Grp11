# ═════════════════════════════════════════════════════════
# Docker build context exclusions
# These files are never needed inside any Docker image.
# Excluding them speeds up `docker build` significantly.
# ═════════════════════════════════════════════════════════

# ── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.eggs/
dist/
build/
*.egg
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
*.so

# ── Node / Frontend ─────────────────────────────────────
node_modules/
.pnp/
.pnp.js
.next/
out/

# ── Git ─────────────────────────────────────────────────
.git/
.gitignore
.gitattributes
.gitmodules

# ── IDE & Editor ────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Environment & Secrets ───────────────────────────────
.env
.env.*
!.env.example

# ── Documentation (not needed at runtime) ───────────────
*.md
!README.md
docs/
plots/

# ── Data files (mounted as volume at runtime) ───────────
data/

# ── Docker & CI ─────────────────────────────────────────
Dockerfile*
docker-compose*.yml
.dockerignore
.github/
.gitlab-ci.yml
