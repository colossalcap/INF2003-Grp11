# ============================================================
# INF2003 Group 11 — E-Commerce Analytics Environment Config
# Copy this file to .env and fill in values for local/dev use.
# Docker Compose sets these automatically — no .env needed.
# ============================================================

# PostgreSQL
POSTGRES_USER=ecommerce_user
POSTGRES_PASSWORD=ecommerce_pass
POSTGRES_DB=ecommerce_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://ecommerce_user:ecommerce_pass@localhost:5432/ecommerce_db

# MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=ecommerce_nosql
MONGO_URI=mongodb://localhost:27017

# JWT Authentication
JWT_SECRET_KEY=change-this-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Backend
BACKEND_PORT=8000
DEBUG=false

# Frontend
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:8000

# Fraud Detection
FRAUD_EVENT_THRESHOLD=10
FRAUD_TIME_WINDOW_SECONDS=60

# Outbox Processor (CDC sync interval in seconds)
OUTBOX_POLL_INTERVAL=5
